{
  "sourceLanguage" : "en",
  "strings" : {
    "NSPhotoLibraryAddUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace saves review recordings and exports when you choose to save them."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace는 사용자가 저장을 선택할 때 리뷰 녹화와 내보내기 파일을 사진 보관함에 저장합니다."
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace lets you import existing screen recordings to generate review transcripts."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace는 기존 화면 녹화를 가져와 리뷰 전사를 만들 수 있도록 사진 보관함 접근을 사용합니다."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace uses speech recognition to turn your spoken app review notes into a timestamped transcript."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ReviewTrace는 음성으로 남긴 앱 리뷰를 타임스탬프 전사로 만들기 위해 음성 인식을 사용합니다."
          }
        }
      }
    }
  },
  "version" : "1.0"
}
